{
    "name": "community-sdks/unlayer-livewire",
    "description": "Livewire wrapper for the unofficial Unlayer Alpine.js SDK.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "CommunitySdks\\UnlayerLivewire\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24"
    },
    "extra": {
        "laravel": {
            "providers": [
                "CommunitySdks\\UnlayerLivewire\\UnlayerLivewireServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
